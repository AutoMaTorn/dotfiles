set $super Mod4
set $alt Mod1

font pango:monospace 14
floating_modifier $super

exec_always --no-startup-id feh --bg-fill ~/dotfiles/.config/wallpapers/wallpaper.jpeg
exec_always --no-startup-id setxkbmap -layout us,ru -option 'grp:alt_shift_toggle'
exec --no-startup-id picom
exec --no-startup-id xrandr --output HDMI-2 --mode 1920x1080
exec --no-startup-id nmcli general reload
exec --no-startup-id nmcli radio wifi on

bindsym $super+Return exec kitty
bindsym $super+space exec --no-startup-id rofi -show drun -no-default-config -config ~/.config/rofi/config.rasi
bindsym $super+shift+s exec --no-startup-id maim -s | xclip -selection clipboard -t image/png
bindsym $super+l exec i3lock-fancy
bindsym $super+e exec thunar
bindsym $super+w exec yandex-browser
bindsym $super+t exec flatpak run org.telegram.desktop

bindsym XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86MonBrightnessDown exec brightnessctl s 5%-
bindsym XF86MonBrightnessUp exec brightnessctl s +5%+

bindsym $super+q kill

bindsym $super+Left focus left
bindsym $super+Down focus down
bindsym $super+Up focus up
bindsym $super+Right focus right

bindsym $super+Shift+Left move left
bindsym $super+Shift+Down move down
bindsym $super+Shift+Up move up
bindsym $super+Shift+Right move right

bindsym $super+h split h
bindsym $super+v split v

bindsym $super+f fullscreen toggle
bindsym $alt+space floating toggle
bindsym $super+Shift+space focus mode_toggle

bindsym $alt+Tab workspace next
bindsym $alt+Shift+Tab workspace prev
bindsym $super+Control+Right workspace next
bindsym $super+Control+Left workspace prev
bindsym $super+1 workspace 1
bindsym $super+2 workspace 2
bindsym $super+3 workspace 3
bindsym $super+4 workspace 4
bindsym $super+5 workspace 5
bindsym $super+6 workspace 6
bindsym $super+7 workspace 7
bindsym $super+8 workspace 8
bindsym $super+9 workspace 9
bindsym $super+0 workspace 10

bindsym $super+Shift+1 move container to workspace 1
bindsym $super+Shift+2 move container to workspace 2
bindsym $super+Shift+3 move container to workspace 3
bindsym $super+Shift+4 move container to workspace 4
bindsym $super+Shift+5 move container to workspace 5
bindsym $super+Shift+6 move container to workspace 6
bindsym $super+Shift+7 move container to workspace 7
bindsym $super+Shift+8 move container to workspace 8
bindsym $super+Shift+9 move container to workspace 9
bindsym $super+Shift+0 move container to workspace 10

bindsym $super+BackSpace exec "i3-msg restart"
bindsym $super+shift+e exec "i3-nagbar -t warning -m 'Really, exit?' -b 'Yes' 'i3-msg exit'"

bindsym $super+r mode "resize"
mode "resize" {
    bindsym Left resize shrink width 5 px or 5 ppt
    bindsym Down resize grow height 5 px or 5 ppt
    bindsym Up resize shrink height 5 px or 5 ppt
    bindsym Right resize grow width 5 px or 5 ppt
    bindsym Return mode "default"
}

exec_always --no-startup-id ~/.config/polybar/launch.sh

client.focused #ededed #181818 #ededed #ededed #ededed
client.focused_inactive #181818 #181818 #ededed #181818 #181818
client.unfocused #181818 #181818 #ededed #181818 #181818
client.urgent #ff7f7f #181818 #ededed #ff7f7f #ff7f7f
client.placeholder #181818 #181818 #ededed #181818 #181818
client.background #181818

for_window [class=".*"] border pixel 3
hide_edge_borders smart
gaps inner 10
gaps outer 5
